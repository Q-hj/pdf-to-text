{
  "name": "pdf-to-text",
  "version": "1.0.0",
  "description": "PDF to text converter with CLI and Web API support",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "pdf2text": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "cli": "node src/cli.js",
    "build": "node scripts/build.js",
    "build:server": "esbuild src/server.js --bundle --platform=node --outfile=dist/server.cjs --format=cjs --external:canvas --external:sharp --external:pdf2pic --external:tesseract.js",
    "build:cli": "esbuild src/cli.js --bundle --platform=node --outfile=dist/cli.cjs --format=cjs --external:canvas --external:sharp --external:pdf2pic --external:tesseract.js",
    "build:docker": "docker build -t pdf-to-text:latest .",
    "build:docker-no-cache": "docker build --no-cache -t pdf-to-text:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "clean": "rm -rf temp/ocr_images/*",
    "clean:dist": "rm -rf dist"
  },
  "keywords": [
    "pdf",
    "text",
    "converter",
    "cli",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "canvas": "^3.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^5.6.205",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1"
  }
}
